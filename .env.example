# Server
PORT=3000
NODE_ENV=production

# Admin Secret — used to protect /oauth and /devices routes
# Generate with: openssl rand -hex 32
ADMIN_SECRET_KEY=replace_with_long_random_string

# Cron Secret — used to protect the /api/cron/refresh-token endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET=replace_with_long_random_string

# Ring Developer Credentials
# Get from: https://developer.ring.com
RING_CLIENT_ID=your_ring_client_id
RING_CLIENT_SECRET=your_ring_client_secret
RING_HMAC_KEY=your_ring_hmac_signing_key
RING_OAUTH_URL=https://oauth.ring.com/oauth/token
RING_API_BASE=https://api.ring.com

# Supabase — Database + Storage
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Supabase — PostgreSQL direct connection
# Get from: Supabase Dashboard → Settings → Database → URI (use "Transaction" mode for serverless)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-ID].supabase.co:5432/postgres

# Firebase Cloud Messaging (push notifications)
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# OpenAI — enables AI vision classification via GPT-4o
# Get from: https://platform.openai.com/api-keys
# Leave blank to use built-in fallback summaries
OPENAI_API_KEY=your_openai_key
