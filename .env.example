# Server
PORT=3000
NODE_ENV=production

# Admin Secret — used to protect /oauth and /devices routes
# Generate with: openssl rand -hex 32
ADMIN_SECRET_KEY=replace_with_long_random_string

# Ring Developer Credentials
RING_CLIENT_ID=your_ring_client_id
RING_CLIENT_SECRET=your_ring_client_secret
RING_HMAC_KEY=your_ring_hmac_signing_key
RING_OAUTH_URL=https://oauth.ring.com/oauth/token
RING_API_BASE=https://api.amazonvision.com

# Supabase (replaces PostgreSQL + AWS S3)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Firebase Cloud Messaging (push notifications)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="your_firebase_private_key"

# OpenAI — enables AI vision classification
# Leave blank to use built-in fallback summaries
OPENAI_API_KEY=your_openai_key
