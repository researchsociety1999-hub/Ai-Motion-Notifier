# Server
PORT=3000
NODE_ENV=production

# Admin Secret — used to protect /oauth and /devices routes
# Generate with: openssl rand -hex 32
ADMIN_SECRET_KEY=replace_with_long_random_string

# Ring Developer Credentials
RING_CLIENT_ID=your_ring_client_id
RING_CLIENT_SECRET=your_ring_client_secret
RING_HMAC_KEY=your_ring_hmac_signing_key
RING_OAUTH_URL=https://oauth.ring.com/oauth/token
RING_API_BASE=https://api.amazonvision.com

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/ring_notifier

# AWS S3 (clip storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-ring-clips-bucket

# Firebase Cloud Messaging (push notifications)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="your_firebase_private_key"

# OpenAI — optional, enables AI event summaries
# Leave blank to use built-in fallback summaries
OPENAI_API_KEY=your_openai_key
